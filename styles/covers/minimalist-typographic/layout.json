{
  "style": "minimalist-typographic",
  "engine": "css",
  "model": "none",
  "aspect": "1:1.414",
  "text_in_image": true,
  "overlay": {
    "title": {
      "position": { "ltr": "center", "rtl": "center" },
      "top_percent": 35,
      "color": "#2A2A2A",
      "size_pt": 48,
      "weight": 600,
      "line_height": 1.1,
      "letter_spacing_en": "-0.01em",
      "letter_spacing_ar": "normal",
      "max_lines": 3
    },
    "subtitle": {
      "position": { "ltr": "center", "rtl": "center" },
      "offset_pt_below_title": 16,
      "color": "#C85A3E",
      "size_pt": 14,
      "weight": 400,
      "line_height": 1.3,
      "max_lines": 2
    },
    "rule": {
      "position": "center",
      "top_percent": 45,
      "width_mm": 30,
      "thickness_pt": 0.5,
      "color": "#CFC4AF"
    },
    "reference_code": {
      "position": { "ltr": "bottom-left", "rtl": "bottom-right" },
      "offset_mm": { "bottom": 20, "side": 20 },
      "color": "#7A7268",
      "size_pt": 9,
      "weight": 400,
      "font": "mono"
    },
    "date": {
      "position": { "ltr": "bottom-right", "rtl": "bottom-left" },
      "offset_mm": { "bottom": 20, "side": 20 },
      "color": "#7A7268",
      "size_pt": 9,
      "weight": 400,
      "font": "mono"
    }
  },
  "contrast_contract": {
    "title_min_ratio": 8.0,
    "subtitle_min_ratio": 4.5,
    "reference_min_ratio": 4.5
  }
}
