{
  "domain": "formal",
  "description": "Institutional correspondence — NOCs, government letters, circulars, authority letters. GCC-aware: bilingual headers, Islamic greeting formulas, honorific addresses. Restrained single-ink typography on off-white.",
  "brand": {
    "ink": "#1F2937",
    "accent": "#0B3D66",
    "muted": "#64748B",
    "page_bg": "#FDFDFB",
    "stamp_red": "#991B1B"
  },
  "semantic_colors": {
    "--page-bg": "#FDFDFB",
    "--accent": "#0B3D66",
    "--accent-2": "#64748B",
    "--accent-on": "#FFFFFF",
    "--text": "#1F2937",
    "--text-secondary": "#374151",
    "--text-tertiary": "#6B7280",
    "--border": "#D1D5DB",
    "--border-strong": "#9CA3AF",
    "--tag-bg": "#E5E7EB",
    "--tag-fg": "#1F2937",
    "--code-bg": "#F3F4F6",
    "--code-fg": "#1F2937",
    "--stamp-red": "#991B1B",
    "--field-label": "#6B7280",
    "--field-value": "#111827"
  },
  "fonts": {
    "en": {
      "primary": "Georgia",
      "display": "Georgia",
      "fallback": "'Times New Roman', Times, serif"
    },
    "ar": {
      "primary": "Amiri",
      "display": "Amiri",
      "fallback": "'Traditional Arabic', Tahoma, serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "noc":              { "top": 30, "right": 25, "bottom": 25, "left": 25 },
      "government-letter":{ "top": 30, "right": 25, "bottom": 28, "left": 25 },
      "circular":         { "top": 25, "right": 25, "bottom": 25, "left": 25 },
      "authority-letter": { "top": 30, "right": 25, "bottom": 28, "left": 25 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["body"],
  "page_numbering": {
    "body_start_at": 1
  },
  "numerals": {
    "en": "western",
    "ar": "arabic-indic"
  },
  "reference_codes": {
    "noc":       "NOC-{YYYY}-{NNN}",
    "gov":       "GOV-{YYYY}-{NNN}",
    "circular":  "CIR-{YYYY}-{NNN}",
    "authority": "AUTH-{YYYY}-{NNN}"
  },
  "formal_phrases": {
    "en": {
      "to_whom_it_may_concern": "TO WHOM IT MAY CONCERN",
      "regards": "Yours sincerely,",
      "salutation_male": "Dear Mr.",
      "salutation_female": "Dear Ms."
    },
    "ar": {
      "islamic_greeting": "السلام عليكم ورحمة الله وبركاته",
      "to_whom_it_may_concern": "إلى مَن يهمّه الأمر",
      "honorific_male": "المحترم",
      "honorific_female": "المحترمة",
      "closing_formula": "وتفضّلوا بقبول فائق الاحترام والتقدير"
    }
  }
}
