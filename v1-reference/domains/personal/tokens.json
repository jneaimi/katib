{
  "domain": "personal",
  "description": "Personal career documents — CV, cover letter, bio. Clean recruiter-friendly layout on warm paper; single accent stripe. GCC-aware fields (nationality, visa, languages). Inter + Cairo sans-serif.",
  "brand": {
    "ink": "#1A1A1A",
    "accent": "#1E3A8A",
    "accent_soft": "#3B82F6",
    "muted": "#6B7280",
    "page_bg": "#FDFCF8",
    "sidebar_bg": "#1E3A8A"
  },
  "semantic_colors": {
    "--page-bg": "#FDFCF8",
    "--accent": "#1E3A8A",
    "--accent-2": "#3B82F6",
    "--accent-on": "#FFFFFF",
    "--text": "#1A1A1A",
    "--text-secondary": "#4B5563",
    "--text-tertiary": "#6B7280",
    "--border": "#E5E7EB",
    "--border-strong": "#9CA3AF",
    "--tag-bg": "#DBEAFE",
    "--tag-fg": "#1E3A8A",
    "--code-bg": "#F3F4F6",
    "--code-fg": "#1F2937",
    "--sidebar-bg": "#1E3A8A",
    "--sidebar-fg": "#FFFFFF",
    "--sidebar-muted": "#BFDBFE",
    "--level-filled": "#1E3A8A",
    "--level-empty": "#DBEAFE"
  },
  "fonts": {
    "en": {
      "primary": "Inter",
      "display": "Inter",
      "fallback": "-apple-system, 'Helvetica Neue', sans-serif"
    },
    "ar": {
      "primary": "Cairo",
      "display": "Cairo",
      "fallback": "'IBM Plex Arabic', Tahoma, sans-serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "cv":           { "top": 0, "right": 0, "bottom": 0, "left": 0 },
      "cover-letter": { "top": 30, "right": 25, "bottom": 28, "left": 25 },
      "bio":          { "top": 25, "right": 25, "bottom": 25, "left": 25 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["body"],
  "page_numbering": {
    "body_start_at": 1
  },
  "numerals": {
    "en": "western",
    "ar": "western"
  },
  "reference_codes": {
    "cv":  "CV-{YYYY}",
    "cl":  "CL-{YYYY}-{NNN}",
    "bio": "BIO-{YYYY}"
  }
}
