{
  "domain": "academic",
  "description": "Academic documents — syllabus, assignment brief, lecture notes, research proposal. Editorial-academic palette (burgundy + sage) on cream paper. Newsreader serif for EN, Amiri for AR. Brand-neutral defaults; swap via --brand.",
  "brand": {
    "burgundy": "#7E1D4A",
    "burgundy_soft": "#A13560",
    "sage": "#5F6B3C",
    "ink": "#1B1918",
    "ink_soft": "#4B4540",
    "muted": "#8A8278",
    "page_bg": "#FBF8F2",
    "rule_line": "#D4CDBE"
  },
  "semantic_colors": {
    "--page-bg": "#FBF8F2",
    "--accent": "#7E1D4A",
    "--accent-2": "#5F6B3C",
    "--accent-on": "#FFFFFF",
    "--text": "#1B1918",
    "--text-secondary": "#4B4540",
    "--text-tertiary": "#8A8278",
    "--border": "#D4CDBE",
    "--border-strong": "#A39B8A",
    "--tag-bg": "#F1E6EC",
    "--tag-fg": "#7E1D4A",
    "--code-bg": "#F3EEE3",
    "--code-fg": "#1B1918",
    "--table-header-bg": "#7E1D4A",
    "--table-row-alt": "#F5F1E8",
    "--callout-bg": "#EFF1E6",
    "--callout-border": "#5F6B3C",
    "--warning-bg": "#FDF6E3",
    "--warning-border": "#B45309"
  },
  "fonts": {
    "en": {
      "primary": "Newsreader",
      "display": "Newsreader",
      "fallback": "Georgia, 'Times New Roman', serif"
    },
    "ar": {
      "primary": "Amiri",
      "display": "Amiri",
      "fallback": "'Traditional Arabic', Tahoma, serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "syllabus":          { "top": 22, "right": 22, "bottom": 22, "left": 22 },
      "assignment-brief":  { "top": 22, "right": 22, "bottom": 22, "left": 22 },
      "lecture-notes":     { "top": 22, "right": 22, "bottom": 22, "left": 22 },
      "research-proposal": { "top": 25, "right": 25, "bottom": 25, "left": 25 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["body"],
  "page_numbering": {
    "body_start_at": 1
  },
  "numerals": {
    "en": "western",
    "ar": "western"
  },
  "reference_codes": {
    "syllabus":          "SYL-{YYYY}-{NNN}",
    "assignment-brief":  "AB-{YYYY}-{NNN}",
    "lecture-notes":     "LN-{YYYY}-{NNN}",
    "research-proposal": "RP-{YYYY}-{NNN}"
  }
}
