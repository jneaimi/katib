{
  "domain": "business-proposal",
  "description": "Corporate proposals, SOWs, commercial offers. Navy + gold institutional palette (override per-client via brand profiles).",
  "brand": {
    "navy": "#1B2A4A",
    "gold": "#C5A44E",
    "dark_gray": "#333333",
    "med_gray": "#666666",
    "light_gray": "#F2F2F2",
    "page_bg": "#FAFAF8"
  },
  "semantic_colors": {
    "--page-bg": "#FAFAF8",
    "--accent": "#1B2A4A",
    "--accent-2": "#C5A44E",
    "--accent-on": "#FFFFFF",
    "--text": "#1A1A1A",
    "--text-secondary": "#404040",
    "--text-tertiary": "#6A6A6A",
    "--border": "#D9D9D3",
    "--border-strong": "#BFBEB4",
    "--tag-bg": "#D8DEED",
    "--tag-fg": "#1B2A4A",
    "--code-bg": "#F2F2F0",
    "--code-fg": "#1A1A1A"
  },
  "fonts": {
    "en": {
      "primary": "Arial",
      "display": "Arial",
      "fallback": "Helvetica Neue, system-ui, sans-serif"
    },
    "ar": {
      "primary": "IBM Plex Arabic",
      "display": "IBM Plex Arabic",
      "fallback": "Cairo, Tahoma, sans-serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "proposal": { "top": 20, "right": 22, "bottom": 22, "left": 22 },
      "one-pager": { "top": 15, "right": 18, "bottom": 15, "left": 18 },
      "letter": { "top": 25, "right": 25, "bottom": 25, "left": 25 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["cover", "signature", "body"],
  "page_numbering": {
    "cover": "hidden",
    "signature": "hidden",
    "body_start_at": 3
  },
  "numerals": {
    "en": "western",
    "ar": "arabic-indic"
  },
  "reference_codes": {
    "technical": "PROP-{YYYY}-{NNN}",
    "commercial": "OFFER-{YY}-{NNN}"
  }
}
