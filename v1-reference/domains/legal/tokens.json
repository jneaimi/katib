{
  "domain": "legal",
  "description": "Legal documents — service agreement, MOU, NDA, engagement letter. Conservative navy ink on white for enforceability aesthetic. Newsreader (EN) + Amiri (AR) serif. Brand-neutral defaults; swap via --brand. Templates only — not legal advice.",
  "brand": {
    "navy": "#1E3A5F",
    "navy_soft": "#2D4A73",
    "ink": "#1A202C",
    "ink_soft": "#374151",
    "muted": "#64748B",
    "page_bg": "#FFFFFF",
    "rule_line": "#CBD5E1"
  },
  "semantic_colors": {
    "--page-bg": "#FFFFFF",
    "--accent": "#1E3A5F",
    "--accent-2": "#4A5568",
    "--accent-on": "#FFFFFF",
    "--text": "#1A202C",
    "--text-secondary": "#374151",
    "--text-tertiary": "#64748B",
    "--border": "#CBD5E1",
    "--border-strong": "#94A3B8",
    "--tag-bg": "#E2E8F0",
    "--tag-fg": "#1E3A5F",
    "--code-bg": "#F1F5F9",
    "--code-fg": "#1A202C",
    "--table-header-bg": "#1E3A5F",
    "--table-row-alt": "#F8FAFC",
    "--callout-bg": "#F1F5F9",
    "--callout-border": "#1E3A5F",
    "--disclaimer-bg": "#FEF3C7",
    "--disclaimer-border": "#B45309",
    "--disclaimer-fg": "#78350F"
  },
  "fonts": {
    "en": {
      "primary": "Newsreader",
      "display": "Newsreader",
      "fallback": "Georgia, 'Times New Roman', serif"
    },
    "ar": {
      "primary": "Amiri",
      "display": "Amiri",
      "fallback": "'Traditional Arabic', Tahoma, serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "service-agreement":  { "top": 25, "right": 25, "bottom": 25, "left": 25 },
      "mou":                { "top": 25, "right": 25, "bottom": 25, "left": 25 },
      "nda":                { "top": 25, "right": 25, "bottom": 25, "left": 25 },
      "engagement-letter":  { "top": 25, "right": 28, "bottom": 25, "left": 28 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["body"],
  "page_numbering": {
    "body_start_at": 1
  },
  "numerals": {
    "en": "western",
    "ar": "western"
  },
  "reference_codes": {
    "service-agreement": "SA-{YYYY}-{NNN}",
    "mou":               "MOU-{YYYY}-{NNN}",
    "nda":               "NDA-{YYYY}-{NNN}",
    "engagement-letter": "EL-{YYYY}-{NNN}"
  }
}
