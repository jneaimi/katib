{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jneaimi/katib/schemas/component.yaml.schema.json",
  "title": "Katib component.yaml",
  "description": "Schema for a single component's metadata file.",
  "type": "object",
  "required": ["name", "tier", "version", "namespace", "languages"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "description": "kebab-case component identifier."
    },
    "tier": {
      "type": "string",
      "enum": ["primitive", "section", "cover"]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^(katib|user|@[A-Za-z0-9][A-Za-z0-9_-]*(/[A-Za-z0-9][A-Za-z0-9_-]*)?)$",
      "description": "core=katib, user-local=user, branded=@<name>, community=@<scope>/<name>"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["en", "ar", "bilingual"]
      }
    },
    "requires": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tokens": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "fonts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        },
        "brand_fields": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        }
      }
    },
    "accepts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/inputDef" }
        },
        "slots": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "variants": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
      }
    },
    "page_behavior": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["atomic", "flowing", "flowing-protect-items"],
          "description": "atomic = never split across pages (engine emits break-inside: avoid on root). flowing = split freely. flowing-protect-items = container may split; declared child selectors stay whole."
        },
        "protect_items": {
          "type": "array",
          "items": { "type": "string" },
          "description": "CSS selectors (relative to component root) to protect when mode=flowing-protect-items. Ignored for other modes."
        },
        "break_before": { "type": "string", "enum": ["auto", "always", "avoid"] },
        "break_after":  { "type": "string", "enum": ["auto", "always", "avoid"] },
        "break_inside": { "type": "string", "enum": ["auto", "avoid"] },
        "min_height":   { "type": "string", "pattern": "^[0-9]+(mm|pt|px)$" }
      }
    }
  },
  "$defs": {
    "inputDef": {
      "type": "object",
      "description": "Structured as either {name: {...}} or {name, type, ...}. Validator accepts either form.",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["string", "markdown", "int", "float", "bool", "date", "image", "array", "object"]
        },
        "required": { "type": "boolean", "default": false },
        "default": {},
        "description": { "type": "string" },
        "sources_accepted": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["user-file", "url", "screenshot", "gemini", "inline-svg"]
          },
          "description": "Only valid when type == image."
        },
        "fallback": {
          "type": "string",
          "enum": ["user-file", "url", "screenshot", "gemini", "inline-svg"]
        },
        "fallback_prompt": { "type": "string" }
      }
    }
  }
}
