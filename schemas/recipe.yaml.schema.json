{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jneaimi/katib/schemas/recipe.yaml.schema.json",
  "title": "Katib recipe.yaml",
  "description": "Schema for a recipe (ordered sequence of components that produces one document).",
  "type": "object",
  "required": ["name", "version", "namespace", "languages", "sections"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^(katib|user|@[A-Za-z0-9][A-Za-z0-9_-]*(/[A-Za-z0-9][A-Za-z0-9_-]*)?)$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "domain_hint": { "type": "string" },
    "target_pages": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer", "minimum": 1 }
    },
    "page_limit": { "type": "integer", "minimum": 1 },
    "languages": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["en", "ar", "bilingual"]
      }
    },
    "required_brand_fields": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sectionDef" }
    },
    "when": { "type": "string" },
    "keywords": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "sectionDef": {
      "type": "object",
      "required": ["component"],
      "additionalProperties": false,
      "properties": {
        "component": {
          "type": "string",
          "pattern": "^([a-z][a-z0-9]*(-[a-z0-9]+)*)$"
        },
        "variant": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
        },
        "namespace": {
          "type": "string",
          "pattern": "^(katib|user|@[A-Za-z0-9][A-Za-z0-9_-]*(/[A-Za-z0-9][A-Za-z0-9_-]*)?)$"
        },
        "inputs": { "type": "object" },
        "repeats": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 1 }
        },
        "break_before": {
          "type": "string",
          "enum": ["auto", "always", "avoid"],
          "description": "Override page break before this section instance. Use 'always' for chapter starts that must begin on a fresh page."
        },
        "page_behavior": {
          "type": "string",
          "enum": ["atomic", "flowing"],
          "description": "Override the component's declared pagination mode for this specific instance. Use sparingly — only when a flowing component (like module) wraps a short, self-contained block that must stay whole. Does not support flowing-protect-items at recipe level (that requires child selectors, which is component-author territory)."
        }
      }
    }
  }
}
