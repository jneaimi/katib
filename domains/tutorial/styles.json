{
  "domain": "tutorial",
  "covers_allowed": [
    "minimalist-typographic",
    "neural-cartography",
    "friendly-illustration"
  ],
  "layouts_allowed": [
    "workbook",
    "cheatsheet"
  ],
  "defaults": {
    "cover": "minimalist-typographic",
    "layout": "workbook"
  },
  "doc_types": {
    "how-to": {
      "formats": ["pdf"],
      "default_format": "pdf",
      "default_layout": "workbook",
      "page_limit": 8,
      "target_pages": [2, 6],
      "sections_required": ["body"]
    },
    "cheatsheet": {
      "formats": ["pdf"],
      "default_format": "pdf",
      "default_layout": "cheatsheet",
      "page_limit": 2,
      "target_pages": [1, 2],
      "sections_required": ["body"]
    },
    "tutorial": {
      "formats": ["pdf"],
      "default_format": "pdf",
      "default_layout": "workbook",
      "page_limit": 20,
      "target_pages": [5, 15],
      "sections_required": ["cover", "body"]
    },
    "onboarding": {
      "formats": ["pdf"],
      "default_format": "pdf",
      "default_layout": "workbook",
      "page_limit": 30,
      "target_pages": [10, 25],
      "sections_required": ["cover", "body"]
    },
    "handoff": {
      "formats": ["pdf"],
      "default_format": "pdf",
      "default_layout": "workbook",
      "page_limit": 15,
      "target_pages": [3, 12],
      "sections_required": ["body"]
    },
    "katib-walkthrough": {
      "formats": ["pdf"],
      "default_format": "pdf",
      "default_layout": "workbook",
      "page_limit": 25,
      "target_pages": [8, 18],
      "sections_required": ["cover", "body"]
    }
  }
}
