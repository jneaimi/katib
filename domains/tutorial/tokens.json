{
  "domain": "tutorial",
  "description": "How-tos, cheatsheets, onboarding guides, handoffs. Warm instructional tone.",
  "brand": {
    "ivory": "#FBF8F3",
    "charcoal": "#2A2A2A",
    "terracotta": "#C85A3E",
    "slate_teal": "#3A7D8B",
    "amber": "#B8842A",
    "deep_red": "#B53E3E",
    "sage": "#5A8549",
    "warm_rule": "#E5DED1"
  },
  "semantic_colors": {
    "--page-bg": "#FBF8F3",
    "--accent": "#C85A3E",
    "--accent-2": "#3A7D8B",
    "--accent-on": "#FFFFFF",
    "--text": "#2A2A2A",
    "--text-secondary": "#4A4A4A",
    "--text-tertiary": "#7A7268",
    "--border": "#E5DED1",
    "--border-strong": "#CFC4AF",
    "--tag-bg": "#EFE5D6",
    "--tag-fg": "#2A2A2A",
    "--code-bg": "#F3EEE3",
    "--code-fg": "#2A2A2A",
    "--callout-info-bg": "#EAF1F4",
    "--callout-info-accent": "#3A7D8B",
    "--callout-warn-bg": "#F5EDDA",
    "--callout-warn-accent": "#B8842A",
    "--callout-danger-bg": "#F5E1E1",
    "--callout-danger-accent": "#B53E3E",
    "--callout-tip-bg": "#E8F0E2",
    "--callout-tip-accent": "#5A8549",
    "--step-circle-bg": "#C85A3E",
    "--step-circle-fg": "#FFFFFF",
    "--screenshot-frame": "#CFC4AF"
  },
  "fonts": {
    "en": {
      "primary": "Inter",
      "display": "Inter",
      "mono": "JetBrains Mono",
      "fallback": "system-ui, -apple-system, sans-serif"
    },
    "ar": {
      "primary": "Cairo",
      "display": "Cairo",
      "mono": "JetBrains Mono",
      "fallback": "IBM Plex Arabic, Tahoma, sans-serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "how-to": { "top": 18, "right": 20, "bottom": 20, "left": 20 },
      "cheatsheet": { "top": 12, "right": 14, "bottom": 12, "left": 14 },
      "tutorial": { "top": 18, "right": 20, "bottom": 20, "left": 20 },
      "onboarding": { "top": 20, "right": 22, "bottom": 22, "left": 22 },
      "handoff": { "top": 20, "right": 22, "bottom": 22, "left": 22 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["cover", "body"],
  "page_numbering": {
    "cover": "hidden",
    "body_start_at": 2
  },
  "numerals": {
    "en": "western",
    "ar": "western"
  }
}
