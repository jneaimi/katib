{
  "domain": "editorial",
  "description": "Editorial documents — white papers, magazine-style articles, op-eds, case studies. Long-form reading aesthetic with drop caps, pull quotes, column rules. Magazine-red accent on warm newsprint. Newsreader (EN) + Amiri (AR) serif for extended reading.",
  "brand": {
    "ink": "#111827",
    "ink_soft": "#374151",
    "accent": "#B91C1C",
    "accent_soft": "#DC2626",
    "muted": "#6B7280",
    "page_bg": "#FAFAF5",
    "rule_line": "#C7C3B5"
  },
  "semantic_colors": {
    "--page-bg": "#FAFAF5",
    "--accent": "#B91C1C",
    "--accent-2": "#1F2937",
    "--accent-on": "#FFFFFF",
    "--text": "#111827",
    "--text-secondary": "#374151",
    "--text-tertiary": "#6B7280",
    "--border": "#C7C3B5",
    "--border-strong": "#8F8A7A",
    "--tag-bg": "#F3E4E4",
    "--tag-fg": "#B91C1C",
    "--code-bg": "#F1EEE4",
    "--code-fg": "#111827",
    "--table-header-bg": "#1F2937",
    "--table-row-alt": "#F3F0E5",
    "--callout-bg": "#F7E8E8",
    "--callout-border": "#B91C1C",
    "--quote-rule": "#B91C1C",
    "--drop-cap-color": "#B91C1C"
  },
  "fonts": {
    "en": {
      "primary": "Newsreader",
      "display": "Newsreader",
      "fallback": "Georgia, 'Times New Roman', serif"
    },
    "ar": {
      "primary": "Amiri",
      "display": "Amiri",
      "fallback": "'Traditional Arabic', Tahoma, serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "white-paper": { "top": 25, "right": 25, "bottom": 25, "left": 25 },
      "article":     { "top": 22, "right": 25, "bottom": 22, "left": 25 },
      "op-ed":       { "top": 25, "right": 28, "bottom": 25, "left": 28 },
      "case-study":  { "top": 22, "right": 25, "bottom": 22, "left": 25 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["body"],
  "page_numbering": {
    "body_start_at": 1
  },
  "numerals": {
    "en": "western",
    "ar": "western"
  },
  "reference_codes": {
    "white-paper": "WP-{YYYY}-{NNN}",
    "article":     "ART-{YYYY}-{NNN}",
    "op-ed":       "OP-{YYYY}-{NNN}",
    "case-study":  "CASE-{YYYY}-{NNN}"
  }
}
