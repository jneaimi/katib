{
  "domain": "marketing-print",
  "description": "Marketing print materials — sell-sheets, product briefs, capability statements, slide decks rendered as PDF. Bold orange accent on ink for sales energy. Inter (EN) + Cairo (AR) sans-serif. Brand-neutral defaults; swap via --brand.",
  "brand": {
    "orange": "#EA580C",
    "orange_soft": "#FB923C",
    "orange_tint": "#FED7AA",
    "ink": "#0F172A",
    "ink_soft": "#1E293B",
    "muted": "#64748B",
    "page_bg": "#FFFFFF",
    "surface_tint": "#FFF7ED"
  },
  "semantic_colors": {
    "--page-bg": "#FFFFFF",
    "--accent": "#EA580C",
    "--accent-2": "#0F172A",
    "--accent-on": "#FFFFFF",
    "--accent-tint": "#FED7AA",
    "--surface-tint": "#FFF7ED",
    "--text": "#0F172A",
    "--text-secondary": "#334155",
    "--text-tertiary": "#64748B",
    "--border": "#E2E8F0",
    "--border-strong": "#94A3B8",
    "--tag-bg": "#FED7AA",
    "--tag-fg": "#9A3412",
    "--code-bg": "#F1F5F9",
    "--code-fg": "#0F172A",
    "--table-header-bg": "#0F172A",
    "--table-row-alt": "#FFF7ED",
    "--callout-bg": "#FFF7ED",
    "--callout-border": "#EA580C",
    "--cta-bg": "#EA580C",
    "--cta-fg": "#FFFFFF"
  },
  "fonts": {
    "en": {
      "primary": "Inter",
      "display": "Inter",
      "fallback": "-apple-system, 'Helvetica Neue', Arial, sans-serif"
    },
    "ar": {
      "primary": "Cairo",
      "display": "Cairo",
      "fallback": "'IBM Plex Arabic', Tahoma, sans-serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "sell-sheet":            { "top": 18, "right": 18, "bottom": 18, "left": 18 },
      "product-brief":         { "top": 20, "right": 20, "bottom": 20, "left": 20 },
      "capability-statement":  { "top": 16, "right": 16, "bottom": 16, "left": 16 },
      "slide-deck":            { "top": 0, "right": 0, "bottom": 0, "left": 0 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["body"],
  "page_numbering": {
    "body_start_at": 1
  },
  "numerals": {
    "en": "western",
    "ar": "western"
  },
  "reference_codes": {
    "sell-sheet":           "SS-{YYYY}-{NNN}",
    "product-brief":        "PB-{YYYY}-{NNN}",
    "capability-statement": "CAP-{YYYY}",
    "slide-deck":           "DECK-{YYYY}-{NNN}"
  }
}
