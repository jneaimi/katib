{
  "domain": "financial",
  "description": "Financial documents — UAE VAT-compliant tax invoice, quote, statement of account, financial summary. Emerald + slate palette on warm ivory. Inter (EN) + Cairo (AR) for numeric clarity. Brand-neutral defaults; swap via --brand.",
  "brand": {
    "emerald": "#0F5F4E",
    "emerald_soft": "#2F8A74",
    "slate": "#475569",
    "ink": "#0F1B1A",
    "ink_soft": "#334155",
    "muted": "#64748B",
    "page_bg": "#FBFAF5",
    "rule_line": "#D1D5CB"
  },
  "semantic_colors": {
    "--page-bg": "#FBFAF5",
    "--accent": "#0F5F4E",
    "--accent-2": "#B4944E",
    "--accent-on": "#FFFFFF",
    "--text": "#0F1B1A",
    "--text-secondary": "#334155",
    "--text-tertiary": "#64748B",
    "--border": "#D1D5CB",
    "--border-strong": "#94A3A4",
    "--tag-bg": "#E0EDE7",
    "--tag-fg": "#0F5F4E",
    "--code-bg": "#F1F0E8",
    "--code-fg": "#0F1B1A",
    "--table-header-bg": "#0F5F4E",
    "--table-row-alt": "#F4F2E9",
    "--callout-bg": "#E7EFEA",
    "--callout-border": "#0F5F4E",
    "--warning-bg": "#FDF3E3",
    "--warning-border": "#B4944E",
    "--success-bg": "#E0EDE7",
    "--success-border": "#0F5F4E",
    "--danger-bg": "#FBE4E4",
    "--danger-border": "#B91C1C"
  },
  "fonts": {
    "en": {
      "primary": "Inter",
      "display": "Inter",
      "fallback": "-apple-system, 'Helvetica Neue', Arial, sans-serif"
    },
    "ar": {
      "primary": "Cairo",
      "display": "Cairo",
      "fallback": "'IBM Plex Arabic', Tahoma, sans-serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "invoice":           { "top": 18, "right": 18, "bottom": 18, "left": 18 },
      "quote":             { "top": 20, "right": 20, "bottom": 20, "left": 20 },
      "statement":         { "top": 18, "right": 18, "bottom": 18, "left": 18 },
      "financial-summary": { "top": 22, "right": 22, "bottom": 22, "left": 22 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["body"],
  "page_numbering": {
    "body_start_at": 1
  },
  "numerals": {
    "en": "western",
    "ar": "western"
  },
  "reference_codes": {
    "invoice":           "INV-{YYYY}-{NNN}",
    "quote":             "QUO-{YYYY}-{NNN}",
    "statement":         "STM-{YYYY}-{MM}",
    "financial-summary": "FIN-{YYYY}-Q{Q}"
  }
}
