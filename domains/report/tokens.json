{
  "domain": "report",
  "description": "Long-form structured reports — research, progress, annual, audit. Data-forward palette on warm paper. Brand-neutral defaults; swap via --brand.",
  "brand": {
    "slate": "#2E3A4B",
    "steel": "#546275",
    "accent": "#0F766E",
    "dark_gray": "#1F2937",
    "med_gray": "#6B7280",
    "light_gray": "#F1F5F4",
    "page_bg": "#FAFAF8"
  },
  "semantic_colors": {
    "--page-bg": "#FAFAF8",
    "--accent": "#2E3A4B",
    "--accent-2": "#0F766E",
    "--accent-on": "#FFFFFF",
    "--text": "#1F2937",
    "--text-secondary": "#4B5563",
    "--text-tertiary": "#6B7280",
    "--border": "#D6D3CB",
    "--border-strong": "#A8A39A",
    "--tag-bg": "#E7EEF1",
    "--tag-fg": "#2E3A4B",
    "--code-bg": "#F1EFE8",
    "--code-fg": "#1F2937",
    "--table-header-bg": "#2E3A4B",
    "--table-row-alt": "#F5F3EB",
    "--callout-bg": "#EEF5F3",
    "--callout-border": "#0F766E"
  },
  "fonts": {
    "en": {
      "primary": "Newsreader",
      "display": "Newsreader",
      "fallback": "Georgia, 'Times New Roman', serif"
    },
    "ar": {
      "primary": "Amiri",
      "display": "Amiri",
      "fallback": "'Traditional Arabic', Tahoma, serif"
    }
  },
  "page": {
    "size": "A4",
    "portrait": true,
    "margins_mm": {
      "research-report": { "top": 22, "right": 22, "bottom": 22, "left": 22 },
      "progress-report": { "top": 20, "right": 22, "bottom": 22, "left": 22 },
      "annual-report":   { "top": 22, "right": 22, "bottom": 22, "left": 22 },
      "audit-report":    { "top": 22, "right": 22, "bottom": 22, "left": 22 }
    },
    "cover_margins_mm": { "top": 0, "right": 0, "bottom": 0, "left": 0 }
  },
  "sections": ["cover", "toc", "body", "appendix"],
  "page_numbering": {
    "cover": "hidden",
    "toc": "roman",
    "body_start_at": 1
  },
  "numerals": {
    "en": "western",
    "ar": "arabic-indic"
  },
  "reference_codes": {
    "research": "RPT-R-{YYYY}-{NNN}",
    "progress": "RPT-P-{YYYY}-{NNN}",
    "annual":   "RPT-A-{YYYY}",
    "audit":    "RPT-AU-{YYYY}-{NNN}"
  }
}
